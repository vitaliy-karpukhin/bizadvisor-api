# База данных (локально через docker-compose)
DB_USER=admin
DB_PASSWORD=your_password_here
DB_NAME=bizadvisor
DB_HOST=db
DB_PORT=5432

# На Render вместо этих переменных будет одна DATABASE_URL (добавляется автоматически)

# JWT
SECRET_KEY=your-very-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# OpenAI (для AI-анализа документов)
OPENAI_API_KEY=sk-...

# CORS — через запятую список разрешённых доменов фронтенда
# Локально можно оставить пустым (разрешает все)
# На проде: https://your-app.vercel.app,https://your-custom-domain.com
CORS_ORIGINS=

# Email (для уведомлений, опционально)
SMTP_EMAIL=your@email.com
SMTP_PASSWORD=your_smtp_password
